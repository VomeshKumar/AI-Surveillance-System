JWT_SECRET=super-secret-fallback-key-change-in-prod
POSTGRES_URL=postgresql+asyncpg://postgres:admin123@127.0.0.1:5432/ai_surveillance

# SMTP setup for forgot-password OTP emails
# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=cor.ri.d.o.r.f.g.j@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SENDER_EMAIL=cor.ri.d.o.r.f.g.j@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=#gmail-username
SMTP_PASSWORD=#gmail-app-password
SMTP_SENDER_EMAIL=#gmail-username
SMTP_SENDER_NAME=AI Surveillance
SMTP_USE_TLS=true

FACE_IMAGE_ROOT=d:/Projects/vision ai/storage/images
