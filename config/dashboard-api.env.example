# API
JWT_SECRET=change-me
POSTGRES_URL=postgresql+asyncpg://aisurv_user:password@127.0.0.1:5433/ai_surveillance
REDIS_URL=redis://127.0.0.1:6379/0

# Consumer scaling
STREAM_MODE=dual
STREAM_SHARDS=6
CONSUMERS_PER_SHARD=1

# Backpressure
STREAM_SOFT_LIMIT=1000
STREAM_HARD_LIMIT=3000
LOW_CONFIDENCE_LIMIT=0.75
HIGH_CONFIDENCE_PRESERVE=0.90
DETECTION_DEDUP_WINDOW_SEC=2.0

# Adaptive sampler
# Policies are written per camera in Redis hash ai:camera_policy:<camera_id>

# Inference service
INFERENCE_BATCH_SIZE=4
INFERENCE_BATCH_TIMEOUT_MS=50

# Database pool (through PgBouncer)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
PGBOUNCER_PORT=5433

# Face image storage (buffered async writes)
FACE_IMAGE_ROOT=face_images
FACE_IMAGE_WORKERS=2
FACE_IMAGE_QUEUE_SIZE=200
FACE_IMAGE_DISK_WARN_THRESHOLD=0.80
FACE_IMAGE_THROTTLE_SEC=0.10
FACE_IMAGE_FSYNC=false

# Auth hardening
OTP_TTL_SECONDS=600
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=300
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW_SECONDS=600

